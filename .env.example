# ── Lokální vývoj (výchozí hodnoty) ──────────────────────────────────────────
POSTGRES_DB=issue_bridge
POSTGRES_USER=issue_bridge
POSTGRES_PASSWORD=issue_bridge
POSTGRES_DATA_DIR=./.data/postgres
ATTACHMENTS_HOST_DIR=./.data/attachments
# Volitelné pro native běh; Docker compose používá výchozí neperzistentní cache v kontejneru.
# ATTACHMENT_CACHE_DIR=./.data/attachment-cache
TEMP_UPLOAD_RETENTION_HOURS=24
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_STALE_AFTER_SECONDS=60
QUEUE_STALE_AFTER_SECONDS=300
SESSION_COOKIE_SECURE=false
DEBUG=false
REQUIRE_SECRET_ENCRYPTION_KEY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_LOGIN_PER_EMAIL=5
RATE_LIMIT_LOGIN_PER_IP=50
RATE_LIMIT_PASSWORD_RECOVERY_PER_EMAIL=3
RATE_LIMIT_PASSWORD_RECOVERY_PER_IP=20
RATE_LIMIT_INVITATION_RESEND_PER_ADMIN=10
RATE_LIMIT_UPLOADS_PER_USER=60
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain,text/csv,application/json,application/zip
TRAEFIK_PORT=3000
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=admin1234
INIT_ADMIN_FULL_NAME=Default Admin
API_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_FRONTEND_URL=http://localhost:3000
SECRET_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_FROM_NAME=IssueHub
SMTP_STARTTLS=true
RUST_LOG=info
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:8080

# ── Produkce — přepsat v .env na serveru ──────────────────────────────────────
# DOMAIN=issuehub.example.com
# ACME_EMAIL=admin@example.com
# FRONTEND_ORIGIN=https://issuehub.example.com
# PUBLIC_FRONTEND_URL=https://issuehub.example.com
# POSTGRES_PASSWORD=silne_heslo
# POSTGRES_DATA_DIR=/var/lib/issuehub/postgres
# ATTACHMENTS_HOST_DIR=/var/lib/issuehub/attachments
# ATTACHMENT_CACHE_DIR=/var/cache/issuehub/gitlab-attachments
# SECRET_ENCRYPTION_KEY=          # openssl rand -base64 32
# SESSION_COOKIE_SECURE=true
# DEBUG=false
# REQUIRE_SECRET_ENCRYPTION_KEY=true
# WORKER_HEARTBEAT_INTERVAL_SECONDS=15
# WORKER_STALE_AFTER_SECONDS=60
# QUEUE_STALE_AFTER_SECONDS=300
# RATE_LIMIT_ENABLED=true
# UPLOAD_MAX_BYTES=10485760
# SMTP_HOST=smtp.example.com
# SMTP_USERNAME=issuehub@example.com
# SMTP_PASSWORD=heslo
# SMTP_FROM_EMAIL=issuehub@example.com
# RUST_LOG=warn
